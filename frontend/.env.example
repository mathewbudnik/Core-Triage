# Frontend environment variables. Copy to .env locally; set in Vercel for prod.

# Backend API base URL. Empty string = same origin (production).
# In dev, point at your local FastAPI: http://localhost:8000
VITE_API_URL=

# Sentry DSN for error tracking. Get yours at https://sentry.io
# This value is safe to expose — it gets baked into the JS bundle.
VITE_SENTRY_DSN=

# App version label that shows up next to errors in Sentry. In Vercel, set
# this to $VERCEL_GIT_COMMIT_SHA so each deploy is tagged with its git SHA.
VITE_APP_VERSION=dev
