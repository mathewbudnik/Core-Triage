# CoreTriage environment variables
# Copy this file to .env and fill in real values — NEVER commit .env to git

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
CORETRIAGE_DB_HOST=localhost
CORETRIAGE_DB_PORT=5432
CORETRIAGE_DB_NAME=coretriage_db
CORETRIAGE_DB_USER=coretriage
CORETRIAGE_DB_PASSWORD=your_db_password_here

# ── Coach admin ───────────────────────────────────────────────────────────────
# On first startup, the user with this email is automatically promoted to
# role='coach' in the database. Used as a one-time seed only.
COACH_EMAIL=your_email_here

# ── Frontend base URL ─────────────────────────────────────────────────────────
# Used to build email-verification links and Stripe Checkout return URLs.
# Dev: http://localhost:5173 (Vite). Prod: https://coretriage.com
FRONTEND_BASE_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get a key at https://resend.com (free tier: 100/day, 3k/month).
# If unset, verification emails are silently skipped — useful for local dev.
RESEND_API_KEY=re_your_key_here
# From-address. Defaults to onboarding@resend.dev (works without domain
# verification). For production, verify your domain in the Resend dashboard
# and set this to e.g. "CoreTriage <noreply@coretriage.com>".
RESEND_FROM_EMAIL=CoreTriage <onboarding@resend.dev>

# ── Stripe (test mode for development; swap to live for production) ──────────
# Get test keys at https://dashboard.stripe.com (toggle Test mode in top-right).
# Create products in Stripe → Products → + Add product, then copy each Price ID.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_PRO=price_your_pro_price_id_here
STRIPE_PRICE_ID_COACHING=price_your_coaching_price_id_here

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
