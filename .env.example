# CoreTriage Environment Variables
# Copy this file to .env and fill in your values.
# The app runs without a database (History tab will be disabled)
# and without an OpenAI key (GPT mode will be disabled).

# ── PostgreSQL (optional) ────────────────────────────────────────────────────
CORETRIAGE_DB_HOST=localhost
CORETRIAGE_DB_PORT=5432
CORETRIAGE_DB_NAME=coretriage_db
CORETRIAGE_DB_USER=coretriage
CORETRIAGE_DB_PASSWORD=

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# Can also be set in .streamlit/secrets.toml as: OPENAI_API_KEY = "sk-..."
OPENAI_API_KEY=sk-...
