# CoreTriage environment variables
# Copy this file to .env and fill in real values — NEVER commit .env to git

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_jwt_secret_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
CORETRIAGE_DB_HOST=localhost
CORETRIAGE_DB_PORT=5432
CORETRIAGE_DB_NAME=coretriage_db
CORETRIAGE_DB_USER=coretriage
CORETRIAGE_DB_PASSWORD=your_db_password_here

# ── Coach admin ───────────────────────────────────────────────────────────────
# This email gets coach inbox access
COACH_EMAIL=your_email_here

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
